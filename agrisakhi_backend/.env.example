# Django
SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=True
DJANGO_PRODUCTION=False

# Database
# Local development uses SQLite by default. Set DATABASE_URL on Railway.
DATABASE_URL=
USE_POSTGRES=False
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_CONN_MAX_AGE=600

# Hosts and browser origins
# Add your custom backend domain when you have one.
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app,.up.railway.app
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://*.railway.app,https://*.up.railway.app,https://*.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$

# Security
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# JWT
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_ALGORITHM=HS256
JWT_SIGNING_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
